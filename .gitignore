# ── Temporary slide preview images (root level only) ──────────────────────────
/sl-*.jpg
/slide-*.jpg

# ── Environment / Secrets (NEVER push these) ──────────────────────────────────
.env
.env.local
.env.production
*.env

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
*.egg

# ── Node / React frontend ──────────────────────────────────────────────────────
node_modules/
build/
.npm
npm-debug.log*

# ── Backend uploads (user-uploaded test files, not source code) ────────────────
backend/uploads/*
uploads/*
!backend/uploads/.gitkeep
!uploads/.gitkeep

# ── OS files ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
